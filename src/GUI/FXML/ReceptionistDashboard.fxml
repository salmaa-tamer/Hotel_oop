<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1024.0" prefHeight="576.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.ReceptionistDashboardController">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>
            <Label fx:id="roleLabel" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" />
            <Label fx:id="hoursLabel" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" />
        </HBox>
    </top>

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50;" prefWidth="250.0">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <Label text="Receptionist" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Menu" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" />

            <Separator style="-fx-background-color: #34495e;" />

            <Button text="Check-In Guest" onAction="#openCheckInScreen" prefWidth="210" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-alignment: BASELINE_LEFT; -fx-padding: 10 15; -fx-cursor: hand;"/>
            <Button text="Check-Out and Payment" onAction="#openCheckOutScreen" prefWidth="210" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-alignment: BASELINE_LEFT; -fx-padding: 10 15; -fx-cursor: hand;"/>

            <Separator style="-fx-background-color: #34495e;" />

            <Label text="Databases" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" />
            <Button text="View All Guests" onAction="#handleViewGuests" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #34495e; -fx-border-radius: 3; -fx-alignment: BASELINE_LEFT; -fx-padding: 10 15; -fx-cursor: hand;" />
            <Button text="View All Rooms" onAction="#handleViewRooms" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #34495e; -fx-border-radius: 3; -fx-alignment: BASELINE_LEFT; -fx-padding: 10 15; -fx-cursor: hand;" />
            <Button text="View All Reservations" onAction="#handleViewReservations" prefWidth="210" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #34495e; -fx-border-radius: 3; -fx-alignment: BASELINE_LEFT; -fx-padding: 10 15; -fx-cursor: hand;" />
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #ffffff;">
            <Label text="System Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Label text="Select an action from the sidebar to begin." style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" />
        </VBox>
    </center>

</BorderPane>